{
  "name": "den-scout",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Self-hosted Stremio stream addon for Den — scrape indexers, cache-check debrid, rank + junk-filter, resolve server-side. The app never sees a torrent or a debrid token.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
