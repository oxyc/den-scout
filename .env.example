# Copy to .env for local `npm run dev` (gitignored). den-scout holds NO debrid secrets: the token
# rides in the addon URL (per install), never the server env. These vars only tune runtime behavior.

# PORT=8080

# Per-indexer scrape timeout (ms) and how long a ranked stream list stays cached (s).
# SCOUT_SCRAPE_TIMEOUT_MS=8000
# SCOUT_LIST_TTL_SECONDS=300

# Per-indexer base-URL overrides. Point these at self-hosted instances, or supply MediaFusion's
# base WITH its encrypted-config segment (it 401s without one). Defaults are the public instances.
# SCOUT_TORRENTIO_URL=https://torrentio.strem.fun
# SCOUT_COMET_URL=https://comet.elfhosted.com
# SCOUT_MEDIAFUSION_URL=https://mediafusion.elfhosted.com/<encrypted-config>
# SCOUT_TORZ_URL=https://torz.strem.fun
